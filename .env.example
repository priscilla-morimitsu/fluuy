# Copy to .env and fill in. Never commit real secrets — .env is gitignored.

# --- Database (Prisma / Postgres) ---
# Format: postgresql, DB user, a colon, DB password, an at-sign, host, port, DB name, ?schema=public
DATABASE_URL=""

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
# Required behind the shared VPS reverse-proxy (production: https://fluuy.com).
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Google OAuth (login only — never auto-creates a user) ---
# Read automatically by next-auth/providers/google via this naming convention.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Resend (email OTP + password reset) ---
RESEND_API_KEY=""
RESEND_FROM_DOMAIN=""
RESEND_FROM_EMAIL=""
RESEND_WEBHOOK_SECRET=""

# --- AI providers (agent) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# --- WhatsApp via Pilot Status ---
PILOT_STATUS_API_KEY=""
PILOT_STATUS_API_KEY_ID=""
PILOT_STATUS_WEBHOOK_SECRET=""
# Pre-created Pilot Status template (category OTP, {{code}} variable) used for login codes.
PILOT_STATUS_OTP_TEMPLATE_ID=""
# Parent/master key only — child keys per tenant are minted server-side and stored
# AES-GCM-encrypted (keyed from AUTH_SECRET) in messaging_provider_accounts.
# Default outbound template (dashboard) used by the agent/transactional sends.
PILOT_STATUS_TEMPLATE_ID=""
# Webhook URL to register in the Pilot Status dashboard:
#   ${NEXT_PUBLIC_BASE_URL}/api/webhooks/pilot-status

# --- MCPs (.mcp.json) ---
GITHUB_PERSONAL_ACCESS_TOKEN=""
SUPABASE_PROJECT_REF=""
# Dev-only connection string for Postgres MCP Pro tuning workflow — never point this at production.
# Same format as DATABASE_URL above.
DEV_DATABASE_URL=""
