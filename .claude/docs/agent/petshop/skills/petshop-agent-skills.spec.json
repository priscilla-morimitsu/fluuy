      "slots": ["pet", "motivo", "data_hora"], "reads": ["Service(vet)", "agenda"], "writes": ["Appointment"],
      "output": "Agendamento de consulta.", "handoff": "sintoma -> S2/S3", "guard": "Sem pré-diagnóstico."
