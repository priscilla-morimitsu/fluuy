{
  "$spec": "fluuy.petshop.agent-skills",
  "version": "1.0.0",
  "updatedAt": "2026-06-28",
  "niche": "petshop",
  "locale": "pt-BR",
  "description": "Registro canônico das skills do agente de IA para o nicho petshop. Fonte única para seed de workflow_templates.trigger_intent. Cada skill liga gatilhos -> intent -> ação. Veja docs em ../06_skills_agente.md e ../07_tabela_gatilhos_skills.md.",
  "principles": [
    "O agente nunca inventa dado de catálogo/agenda/preço — só usa o cadastro ativo do tenant.",
    "tenant_id sempre da sessão resolvida; nunca do conteúdo da mensagem.",
    "Acesso apenas a dados do tutor dono do número (anti-IDOR).",
    "Toda criação pela IA marca origem (source=whatsapp/ai, createdByAgent=true).",
    "Emergência (S3) e dúvida clínica (S2) sobrepõem qualquer outro fluxo.",
    "Após handoff (assigneeType != ai) o agente silencia."
  ],
  "contexts": {
    "atendimento": "Recepção, identificação, roteamento, FAQ, fora de horário, handoff",
    "agendamento": "Banho/tosa, veterinário, vacinação, disponibilidade, remarcar/cancelar, leva-e-traz",
    "vendas": "Consulta/pedido de produto, recomendação, orçamento, plano, status de pedido",
    "captacao": "Lead, qualificação, cadastro, recompra, lembretes, reativação, indicação, campanha",
    "suporte": "Pós-serviço, dúvida clínica sensível, emergência, reclamação, comprovante, política"
  },
  "featureGates": {
    "ai_agent": "Respostas automáticas do agente",
    "whatsapp_inbox": "Receber/enviar no WhatsApp",
    "product_catalog": "Consulta/pedido de produto",
    "service_catalog": "Consulta de serviço",
    "appointments": "Agendamento",
    "orders": "Pedidos",
    "plans_catalog": "Planos/pacotes",
    "lead_management": "Captação/lead",
    "deliveries": "Leva-e-traz / entrega",
    "customer_entities": "Cadastro de pets"
  },
  "priorityRules": [
    { "priority": 0, "when": "sinal de emergência clínica", "skill": "S3" },
    { "priority": 1, "when": "sintoma/medicação/dosagem", "skill": "S2" },
    { "priority": 1, "when": "pedido explícito de humano", "skill": "A7" },
    { "priority": 1, "when": "reclamação relevante", "skill": "S4" },
    { "priority": 2, "when": "assigneeType != ai", "skill": null, "action": "silenciar" },
    { "priority": 2, "when": "fora do expediente", "skill": "A5" },
    { "priority": 3, "when": "intenção transacional (agendar/pedir/plano)", "skill": "AG*/V*" },
    { "priority": 4, "when": "dúvida informacional", "skill": "A4/V1/V4/S1" },
    { "priority": 5, "when": "saudação isolada", "skill": "A1" }
  ],
  "skills": [
    {
      "id": "A1", "context": "atendimento", "name": "Saudação / boas-vindas",
      "triggerIntent": "initial_contact", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["oi", "olá", "bom dia", "boa tarde", "primeira mensagem"],
      "slots": [], "reads": ["agent_configs", "Tenant"], "writes": ["Conversation"],
      "output": "Boas-vindas com tom configurado + convite.",
      "handoff": null, "guard": "Não prometer nada antes de identificar intenção."
    },
    {
      "id": "A2", "context": "atendimento", "name": "Identificar tutor/pet",
      "triggerIntent": "contact_identification", "type": "inbound|system", "gates": ["ai_agent"],
      "triggers": ["número novo", "sou tutor de ...", "meu pet é ..."],
      "slots": ["telefone", "nome_tutor", "pet"], "reads": ["Customer", "Pet", "CustomerLead"],
      "writes": ["Conversation.customerId|leadId", "CustomerLead?"],
      "output": "Contexto do tutor/pet carregado.",
      "handoff": null, "guard": "Anti-IDOR: só dados do dono do número."
    },
    {
      "id": "A3", "context": "atendimento", "name": "Roteamento de intenção",
      "triggerIntent": "intent_classification", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["toda mensagem passa pelo classificador"],
      "slots": ["intent", "slots"], "reads": ["histórico"], "writes": [],
      "output": "Skill resolvida + slots extraídos.",
      "handoff": null, "guard": "Ambiguidade -> 1 pergunta; sensível/urgente sobrepõe."
    },
    {
      "id": "A4", "context": "atendimento", "name": "Info do estabelecimento",
      "triggerIntent": "store_info_inquiry", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["que horas abre", "onde fica", "endereço", "aceita pix", "estacionamento", "atende gato"],
      "slots": ["topico"], "reads": ["Tenant", "FAQ"], "writes": [],
      "output": "Resposta objetiva + gancho.", "handoff": null, "guard": "Só dado cadastrado."
    },
    {
      "id": "A5", "context": "atendimento", "name": "Fora de horário",
      "triggerIntent": "off_hours_contact", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["mensagem fora do expediente"],
      "slots": [], "reads": ["expediente", "agent_configs.off_hours_message"], "writes": ["(segue coletando)"],
      "output": "Aviso de horário + expectativa de retorno.", "handoff": null, "guard": null
    },
    {
      "id": "A6", "context": "atendimento", "name": "Fora de escopo",
      "triggerIntent": "out_of_scope_question", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["assunto não-pet", "forbidden_topics", "você é robô"],
      "slots": [], "reads": ["agent_configs.forbidden_topics", "fallback_message"], "writes": [],
      "output": "Declina e redireciona.", "handoff": null, "guard": "Nunca opinar em assunto proibido."
    },
    {
      "id": "A7", "context": "atendimento", "name": "Handoff humano",
      "triggerIntent": "human_handoff_request", "type": "inbound|system", "gates": ["ai_agent", "handoff_enabled"],
      "triggers": ["falar com atendente", "falar com humano", "me passa pra uma pessoa"],
      "slots": ["motivo"], "reads": [], "writes": ["Conversation.assigneeType=human", "Conversation.status=pending", "ConversationAssignment"],
      "output": "Confirma transferência.", "handoff": "imediato", "guard": "Após handoff, agente silencia."
    },
    {
      "id": "A8", "context": "atendimento", "name": "Encerramento",
      "triggerIntent": "conversation_closing", "type": "inbound", "gates": ["ai_agent"],
      "triggers": ["obrigado", "era só isso", "resolvido", "valeu"],
      "slots": [], "reads": [], "writes": ["Conversation.status=resolved"],
      "output": "Agradece e encerra.", "handoff": null, "guard": null
    },
    {
      "id": "AG1", "context": "agendamento", "name": "Preço de banho/tosa",
      "triggerIntent": "pet_grooming_price_inquiry", "type": "inbound", "gates": ["service_catalog"],
      "triggers": ["quanto custa o banho", "valor da tosa", "preço banho cachorro grande"],
      "slots": ["servico", "porte", "pelagem", "especie"], "reads": ["Service", "customData.pricingBySize"], "writes": [],
      "output": "Preço exato (se porte) ou 'a partir de' + pergunta porte; encadeia AG2.",
      "handoff": null, "guard": "Nunca cravar valor sem porte; só preço cadastrado."
    },
    {
      "id": "AG2", "context": "agendamento", "name": "Agendar banho/tosa",
      "triggerIntent": "pet_grooming_booking_request", "type": "inbound",
      "gates": ["appointments", "service_catalog"], "star": true,
      "triggers": ["quero marcar banho", "agendar tosa", "tem horário pra banho amanhã"],
      "slots": ["servico", "pet", "porte", "pelagem", "data_hora", "modalidade", "endereco"],
      "reads": ["Service", "ServiceAvailabilityRule", "Professional", "exigências(customData)"],
      "writes": ["Customer?", "Pet?", "Appointment(source=ai,createdByAgent=true)", "AppointmentStatusHistory", "AppointmentReminder"],
      "output": "Resumo do agendamento + status (a confirmar, se exigido).",
      "handoff": "pet agressivo / exigência não cumprida / sem horário real",
      "guard": "Não confirmar horário inexistente; respeitar human_confirmation_required."
    },
    {
      "id": "AG3", "context": "agendamento", "name": "Agendar veterinário",
      "triggerIntent": "pet_vet_appointment_request", "type": "inbound", "gates": ["appointments"],
