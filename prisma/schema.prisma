// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// V0 — Fundação técnica: apenas o necessário para autenticação básica.
// users.role discrimina platform_admin desde já, pois a tabela tenant_users
// (Versão 1) referenciará users.id para roles por tenant.
enum UserStatus {
  active
  invited
  disabled
}

model User {
  id              String     @id @default(uuid())
  name            String
  email           String     @unique
  phone           String?    @unique
  avatarUrl       String?    @map("avatar_url")
  isPlatformAdmin Boolean    @default(false) @map("is_platform_admin")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenantUsers         TenantUser[]
  authCredential      AuthCredential?
  authIdentities      AuthIdentity[]
  verificationCodes   AuthVerificationCode[]
  passwordResetTokens PasswordResetToken[]
  collaborators       Collaborator[]
  professionals       Professional[]

  @@map("users")
}

// ============================================================================
// Authentication — see .claude/docs/specs/auth/authentication-flow.spec.json
// and .devrails/rules/security.md. No public signup creates a User/Tenant —
// only the lead form is public (see Lead below).
// ============================================================================

model AuthCredential {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  passwordHash       String   @map("password_hash")
  passwordSetAt      DateTime @default(now()) @map("password_set_at")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}

enum AuthProvider {
  google
}

model AuthIdentity {
  id                    String       @id @default(uuid())
  userId                String       @map("user_id")
  provider              AuthProvider
  providerUserId        String       @map("provider_user_id")
  providerEmail         String?      @map("provider_email")
  providerEmailVerified Boolean      @default(false) @map("provider_email_verified")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

enum OtpChannel {
  email
  whatsapp
}

enum OtpPurpose {
  login
}

model AuthVerificationCode {
  id             String     @id @default(uuid())
  userId         String?    @map("user_id")
  // Hash of the normalized email/phone — never store the raw identifier here
  // longer than needed to send the code; the row is keyed by its hash.
  identifierHash String     @map("identifier_hash")
  channel        OtpChannel
  purpose        OtpPurpose @default(login)
  codeHash       String     @map("code_hash")
  expiresAt      DateTime   @map("expires_at")
  consumedAt     DateTime?  @map("consumed_at")
  attempts       Int        @default(0)
  maxAttempts    Int        @default(5) @map("max_attempts")
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identifierHash, channel, purpose])
  @@index([userId])
  @@map("auth_verification_codes")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  tenantId  String?  @map("tenant_id")
  event     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@index([event, createdAt])
  @@map("auth_audit_logs")
}

enum LeadStatus {
  new
  contacted
  qualified
  discarded
}

model Lead {
  id          String     @id @default(uuid())
  name        String
  companyName String?    @map("company_name")
  email       String
  phone       String?
  niche       String?
  message     String?
  source      String?
  status      LeadStatus @default(new)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@map("leads")
}

// ============================================================================
// V1 — MVP Core Multi-nicho: tenants, niches, templates, features, billing.
// See .devrails/rules/multi-tenant.md for the isolation rules these models
// must satisfy (tenant_id on every query, platform_admin-only niche/template
// management, custom_data validated against templates.fields).
// ============================================================================

enum NicheStatus {
  active
  inactive
}

model Niche {
  id            String      @id @default(uuid())
  key           String      @unique
  name          String
  description   String?
  customerLabel String?     @map("customer_label")
  entityLabel   String?     @map("entity_label")
  status        NicheStatus @default(active)
  createdBy     String?     @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenants   Tenant[]
  templates Template[]

  @@map("niches")
}

enum TemplateEntityType {
  tenant
  customer
  customer_entity
  product
  service
  professional
  plan
  order
  appointment
  request
  agent_config
  collaborator
}

enum TemplateStatus {
  draft
  active
  inactive
}

model Template {
  id          String             @id @default(uuid())
  nicheId     String             @map("niche_id")
  entityType  TemplateEntityType @map("entity_type")
  name        String
  description String?
  // Field definitions used to validate custom_data on the matching entity —
  // see the multi-tenant rule: never hardcode niche-specific fields in code.
  fields      Json               @default("[]")
  config      Json?
  version     Int                @default(1)
  status      TemplateStatus     @default(draft)
  createdBy   String?            @map("created_by")
  updatedBy   String?            @map("updated_by")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  niche Niche @relation(fields: [nicheId], references: [id], onDelete: Restrict)

  @@index([nicheId, entityType])
  @@map("templates")
}

enum TenantStatus {
  active
  trial
  suspended
  blocked
}

model Tenant {
  id                   String       @id @default(uuid())
  nicheId              String       @map("niche_id")
  name                 String
  legalName            String?      @map("legal_name")
  document             String?
  slug                 String       @unique
  description          String?
  logoUrl              String?      @map("logo_url")
  status               TenantStatus @default(trial)
  publicPhone          String?      @map("public_phone")
  publicEmail          String?      @map("public_email")
  notificationPhone    String?      @map("notification_phone")
  address              Json?
  businessHours        Json?        @map("business_hours")
  serviceAreas         Json?        @map("service_areas")
  paymentMethods       Json?        @map("payment_methods")
  hasProducts          Boolean      @default(false) @map("has_products")
  hasServices          Boolean      @default(false) @map("has_services")
  hasPlans             Boolean      @default(false) @map("has_plans")
  hasDelivery          Boolean      @default(false) @map("has_delivery")
  hasPickup            Boolean      @default(false) @map("has_pickup")
  acceptsOnlinePayment Boolean      @default(false) @map("accepts_online_payment")
  atendimentoFlows     Json?        @map("atendimento_flows")
  customData           Json         @default("{}") @map("custom_data")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  niche                            Niche                             @relation(fields: [nicheId], references: [id], onDelete: Restrict)
  tenantUsers                      TenantUser[]
  tenantFeatures                   TenantFeature[]
  products                         Product[]
  productCategories                ProductCategory[]
  services                         Service[]
  serviceCategories                ServiceCategory[]
  professionals                    Professional[]
  locations                        Location[]
  serviceProfessionals             ServiceProfessional[]
  serviceLocations                 ServiceLocation[]
  serviceAvailabilityRules         ServiceAvailabilityRule[]
  professionalSpecialties          ProfessionalSpecialty[]
  professionalSpecialtyAssignments ProfessionalSpecialtyAssignment[]
  professionalLocations            ProfessionalLocation[]
  customers                        Customer[]
  customerAddresses                CustomerAddress[]
  customerTags                     CustomerTag[]
  customerTagAssignments           CustomerTagAssignment[]
  customerEntities                 CustomerEntity[]
  pets                             Pet[]
  customerLeads                    CustomerLead[]
  offerPlans                       OfferPlan[]
  offerPlanCategories              OfferPlanCategory[]
  offerPlanServiceItems            OfferPlanServiceItem[]
  offerPlanProductItems            OfferPlanProductItem[]
  collaborators                    Collaborator[]
  collaboratorRoles                CollaboratorRole[]
  collaboratorDepartments          CollaboratorDepartment[]
  orders                           Order[]
  orderSequence                    OrderSequence?
  appointments                     Appointment[]
  messagingProviderAccounts        MessagingProviderAccount[]
  whatsappAccounts                 WhatsAppAccount[]
  conversations                    Conversation[]
  conversationMessages             ConversationMessage[]
  messageDeliveries                MessageDelivery[]
  messageTemplateMappings          MessageTemplateMapping[]
  messageWebhookEventLogs          MessageWebhookEventLog[]
  messageConsents                  MessageConsent[]
  conversationAssignments          ConversationAssignment[]

  mcpAccessTokens                  McpAccessToken[]

  @@index([nicheId])
  @@index([status])
  @@map("tenants")
}

enum TenantUserRole {
  tenant_owner
  tenant_manager
  tenant_operator
  tenant_viewer
}

enum TenantUserStatus {
  active
  invited
  disabled
}

model TenantUser {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String           @map("user_id")
  role      TenantUserRole
  status    TenantUserStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

enum FeatureStatus {
  active
  inactive
}

model Feature {
  id          String        @id @default(uuid())
  key         String        @unique
  name        String
  description String?
  group       String?
  status      FeatureStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  planFeatures   PlanFeature[]
  tenantFeatures TenantFeature[]

  @@map("features")
}

enum BillingPeriod {
  monthly
  yearly
}

enum BillingPlanStatus {
  active
  inactive
}

model BillingPlan {
  id            String            @id @default(uuid())
  key           String            @unique
  name          String
  description   String?
  price         Decimal           @db.Decimal(10, 2)
  billingPeriod BillingPeriod     @map("billing_period")
  status        BillingPlanStatus @default(active)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  planFeatures PlanFeature[]

  @@map("billing_plans")
}

model PlanFeature {
  id            String   @id @default(uuid())
  billingPlanId String   @map("billing_plan_id")
  featureId     String   @map("feature_id")
  createdAt     DateTime @default(now()) @map("created_at")

  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)
  feature     Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([billingPlanId, featureId])
  @@map("plan_features")
}

enum TenantFeatureSource {
  plan
  manual
  trial
}

model TenantFeature {
  id        String              @id @default(uuid())
  tenantId  String              @map("tenant_id")
  featureId String              @map("feature_id")
  enabled   Boolean             @default(true)
  source    TenantFeatureSource @default(manual)
  expiresAt DateTime?           @map("expires_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId])
  @@index([tenantId])
  @@map("tenant_features")
}

// ── Tenant product catalog (feature: product_catalog) ──────────────────────
enum ProductStatus {
  draft
  active
  inactive
}

enum ProductUnit {
  unit
  kg
  g
  l
  ml
  package
  box
  service_bundle
  other
}

enum ProductCategoryStatus {
  active
  inactive
}

model ProductCategory {
  id          String                @id @default(uuid())
  tenantId    String                @map("tenant_id")
  name        String
  slug        String
  description String?
  status      ProductCategoryStatus @default(active)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("product_categories")
}

model Product {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  categoryId       String?       @map("category_id")
  name             String
  slug             String
  description      String?
  brand            String?
  sku              String?
  barcode          String?
  salePrice        Decimal       @map("sale_price") @db.Decimal(12, 2)
  promotionalPrice Decimal?      @map("promotional_price") @db.Decimal(12, 2)
  costPrice        Decimal?      @map("cost_price") @db.Decimal(12, 2)
  unit             ProductUnit?
  imageUrl         String?       @map("image_url")
  status           ProductStatus @default(draft)
  availableForSale Boolean       @default(true) @map("available_for_sale")
  internalNotes    String?       @map("internal_notes")
  customData       Json          @default("{}") @map("custom_data")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Categories with products cannot be deleted (Restrict) — actions surface a
  // friendly "inactivate instead" message before reaching the DB constraint.
  category       ProductCategory?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  offerPlanItems OfferPlanProductItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@map("products")
}

// ── Tenant service catalog (feature: service_catalog) ──────────────────────
// Phase 1: Service + ServiceCategory. Professional/Location links and the
// decoupled ServiceAvailabilityRule arrive in later phases (the form already
// captures delivery modes so those phases only add relations, not reshape).
enum ServiceStatus {
  draft
  active
  inactive
}

enum ServiceCategoryStatus {
  active
  inactive
}

// Where the service can be delivered. at_location is fulfilled at a tenant
// Location (Phase 2); at_home uses the customer's address at booking time;
// online uses onlineInstructions. A service may combine several modes.
enum ServiceDeliveryMode {
  at_location
  at_home
  online
}

model ServiceCategory {
  id          String                @id @default(uuid())
  tenantId    String                @map("tenant_id")
  name        String
  slug        String
  description String?
  status      ServiceCategoryStatus @default(active)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("service_categories")
}

model Service {
  id                       String                @id @default(uuid())
  tenantId                 String                @map("tenant_id")
  categoryId               String?               @map("category_id")
  name                     String
  slug                     String
  description              String?
  basePrice                Decimal               @map("base_price") @db.Decimal(12, 2)
  promotionalPrice         Decimal?              @map("promotional_price") @db.Decimal(12, 2)
  estimatedDurationMinutes Int?                  @map("estimated_duration_minutes")
  status                   ServiceStatus         @default(draft)
  availableForBooking      Boolean               @default(true) @map("available_for_booking")
  requiresScheduling       Boolean               @default(true) @map("requires_scheduling")
  deliveryModes            ServiceDeliveryMode[] @map("delivery_modes")
  onlineInstructions       String?               @map("online_instructions")
  homeServiceNotes         String?               @map("home_service_notes")
  imageUrl                 String?               @map("image_url")
  internalNotes            String?               @map("internal_notes")
  customData               Json                  @default("{}") @map("custom_data")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Categories with services cannot be deleted (Restrict) — actions surface a
  // friendly "inactivate instead" message before reaching the DB constraint.
  category             ServiceCategory?          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  serviceProfessionals ServiceProfessional[]
  serviceLocations     ServiceLocation[]
  availabilityRules    ServiceAvailabilityRule[]
  offerPlanItems       OfferPlanServiceItem[]
  appointments         Appointment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@map("services")
}

// ── Phase 2: professionals, locations and the (decoupled) service links ─────
enum ProfessionalStatus {
  active
  inactive
}

enum LocationType {
  physical_unit
  room
  office
  store
  clinic
  other
}

enum LocationStatus {
  active
  inactive
}

enum ServiceProfessionalStatus {
  active
  inactive
}

enum ServiceLocationStatus {
  active
  inactive
}

model Professional {
  id            String             @id @default(uuid())
  tenantId      String             @map("tenant_id")
  // Optional link to a User who also logs in (must belong to the same tenant
  // via TenantUser — validated in the action, never trusted from the client).
  userId        String?            @map("user_id")
  name          String
  // Required in the dedicated form; nullable in the DB so the lightweight
  // inline quick-create (from the service form) can create a name-only row.
  title         String?
  bio           String?
  avatarUrl     String?            @map("avatar_url")
  phone         String?
  whatsapp      String?
  email         String?
  status        ProfessionalStatus @default(active)
  publicProfile Boolean            @default(true) @map("public_profile")
  internalNotes String?            @map("internal_notes")
  // CPF, professional registration (CRO/CRMV/CRN/…) live in customData per niche
  // template — never as fixed columns.
  customData    Json               @default("{}") @map("custom_data")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  tenant                Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User?                             @relation(fields: [userId], references: [id], onDelete: SetNull)
  serviceProfessionals  ServiceProfessional[]
  availabilityRules     ServiceAvailabilityRule[]
  specialtyAssignments  ProfessionalSpecialtyAssignment[]
  professionalLocations ProfessionalLocation[]
  collaborators         Collaborator[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@index([tenantId, email])
  @@map("professionals")
}

model Location {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  name       String
  type       LocationType   @default(physical_unit)
  address    Json?
  status     LocationStatus @default(active)
  customData Json           @default("{}") @map("custom_data")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceLocations      ServiceLocation[]
  availabilityRules     ServiceAvailabilityRule[]
  professionalLocations ProfessionalLocation[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("locations")
}

// ── Professionals module: specialties + location links (spec-crud-service-professionals) ──
enum ProfessionalSpecialtyStatus {
  active
  inactive
}

enum ProfessionalLocationStatus {
  active
  inactive
}

model ProfessionalSpecialty {
  id          String                      @id @default(uuid())
  tenantId    String                      @map("tenant_id")
  name        String
  slug        String
  description String?
  status      ProfessionalSpecialtyStatus @default(active)
  createdAt   DateTime                    @default(now()) @map("created_at")
  updatedAt   DateTime                    @updatedAt @map("updated_at")

  tenant      Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments ProfessionalSpecialtyAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("professional_specialties")
}

model ProfessionalSpecialtyAssignment {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  professionalId String   @map("professional_id")
  specialtyId    String   @map("specialty_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional          @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty    ProfessionalSpecialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([professionalId, specialtyId])
  @@index([tenantId, professionalId])
  @@index([tenantId, specialtyId])
  @@map("professional_specialty_assignments")
}

model ProfessionalLocation {
  id             String                     @id @default(uuid())
  tenantId       String                     @map("tenant_id")
  professionalId String                     @map("professional_id")
  locationId     String                     @map("location_id")
  status         ProfessionalLocationStatus @default(active)
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([professionalId, locationId])
  @@index([tenantId, professionalId])
  @@index([tenantId, locationId])
  @@map("professional_locations")
}

// Decoupled service ↔ professional link. deliveryModes optionally limits which
// modalities the professional covers for this service (empty = all the
// service's modes). Override fields are reserved for later phases.
model ServiceProfessional {
  id                      String                    @id @default(uuid())
  tenantId                String                    @map("tenant_id")
  serviceId               String                    @map("service_id")
  professionalId          String                    @map("professional_id")
  deliveryModes           ServiceDeliveryMode[]     @map("delivery_modes")
  priceOverride           Decimal?                  @map("price_override") @db.Decimal(12, 2)
  durationOverrideMinutes Int?                      @map("duration_override_minutes")
  isPrimary               Boolean                   @default(false) @map("is_primary")
  status                  ServiceProfessionalStatus @default(active)
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([serviceId, professionalId])
  @@index([tenantId])
  @@index([serviceId])
  @@index([professionalId])
  @@map("service_professionals")
}

// Decoupled service ↔ location link (only used by the at_location modality).
model ServiceLocation {
  id         String                @id @default(uuid())
  tenantId   String                @map("tenant_id")
  serviceId  String                @map("service_id")
  locationId String                @map("location_id")
  status     ServiceLocationStatus @default(active)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locationId])
  @@index([tenantId])
  @@index([serviceId])
  @@index([locationId])
  @@map("service_locations")
}

// ── Phase 3: decoupled availability rules ──────────────────────────────────
// Weekly windows per service + modality, with optional professional/location.
// weekday: 0–6, 0 = Sunday (JS getDay). startTime/endTime are "HH:mm" strings.
// Invariants (enforced in the action/Zod): at_location ⇒ locationId set;
// at_home/online ⇒ locationId null; startTime < endTime.
enum ServiceAvailabilityRuleStatus {
  active
  inactive
}

model ServiceAvailabilityRule {
  id                  String                        @id @default(uuid())
  tenantId            String                        @map("tenant_id")
  serviceId           String                        @map("service_id")
  professionalId      String?                       @map("professional_id")
  locationId          String?                       @map("location_id")
  deliveryMode        ServiceDeliveryMode           @map("delivery_mode")
  weekday             Int
  startTime           String                        @map("start_time")
  endTime             String                        @map("end_time")
  slotDurationMinutes Int?                          @map("slot_duration_minutes")
  bufferBeforeMinutes Int                           @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int                           @default(0) @map("buffer_after_minutes")
  status              ServiceAvailabilityRuleStatus @default(active)
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  location     Location?     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([serviceId])
  @@index([serviceId, weekday])
  @@map("service_availability_rules")
}

// ── Customers (tenant CRM) ─────────────────────────────────────────────────
// Technical name is "Customer"; the UI label is dynamic per niche
// (niches.customer_label → Tutor / Paciente / Cliente / Interessado …).
// Niche-specific fields live in custom_data validated against the active
// Template (entity_type = customer). document / internal_notes are sensitive
// and must never be exposed to the AI or the customer.
enum CustomerStatus {
  active
  inactive
  blocked
}

enum CustomerPersonType {
  individual
  company
}

enum CustomerSource {
  whatsapp
  instagram
  website
  referral
  manual
  ai
  import
  other
}

model Customer {
  id                 String              @id @default(uuid())
  tenantId           String              @map("tenant_id")
  // Forward-compat link to the originating lead. No FK yet: the current Lead
  // model is a landing-page lead (not tenant-scoped); the WhatsApp/lead-
  // conversion flow lands in a later phase once a tenant Lead model exists.
  leadId             String?             @map("lead_id")
  name               String
  phone              String
  phoneNormalized    String              @map("phone_normalized")
  whatsapp           String?
  whatsappNormalized String?             @map("whatsapp_normalized")
  email              String?
  personType         CustomerPersonType? @map("person_type")
  document           String?
  documentNormalized String?             @map("document_normalized")
  birthDate          DateTime?           @map("birth_date")
  status             CustomerStatus      @default(active)
  source             CustomerSource?
  consentAcceptedAt  DateTime?           @map("consent_accepted_at")
  consentSource      String?             @map("consent_source")
  internalNotes      String?             @map("internal_notes")
  customData         Json                @default("{}") @map("custom_data")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addresses    CustomerAddress[]
  tagLinks     CustomerTagAssignment[]
  entities     CustomerEntity[]
  pets         Pet[]
  orders       Order[]
  appointments Appointment[]

  // One customer per phone, per tenant (strong WhatsApp dedup key).
  @@unique([tenantId, phoneNormalized])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, whatsappNormalized])
  @@map("customers")
}

enum CustomerAddressType {
  main
  delivery
  billing
  home_service
  other
}

model CustomerAddress {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  customerId   String              @map("customer_id")
  type         CustomerAddressType @default(main)
  name         String?
  zipCode      String?             @map("zip_code")
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String              @default("Brasil")
  reference    String?
  isDefault    Boolean             @default(false) @map("is_default")
  customData   Json                @default("{}") @map("custom_data")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@map("customer_addresses")
}

enum CustomerTagStatus {
  active
  inactive
}

model CustomerTag {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  name        String
  slug        String
  color       String?
  description String?
  status      CustomerTagStatus @default(active)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments CustomerTagAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  tagId      String   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@index([tenantId])
  @@index([customerId])
  @@index([tagId])
  @@map("customer_tag_assignments")
}

// Generic, multi-niche object owned by a Customer (pet, vehicle, dependent,
// property_interest, …). Never model these as fixed core tables: entity_type +
// custom_data validated against the active Template (entity_type = customer_entity)
// drive niche-specific shape. Feature gate: customer_entities.
enum CustomerEntityStatus {
  active
  inactive
}

model CustomerEntity {
  id         String               @id @default(uuid())
  tenantId   String               @map("tenant_id")
  customerId String               @map("customer_id")
  entityType String               @map("entity_type")
  name       String
  status     CustomerEntityStatus @default(active)
  customData Json                 @default("{}") @map("custom_data")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, entityType])
  @@map("customer_entities")
}

enum PetStatus {
  active
  inactive
}

enum PetSex {
  male
  female
}

// Petshop-specific pet, owned by a Customer. Dedicated table with concrete
// columns (the MVP drops the generic template/custom_data system for petshop —
// see memory templates-out-of-mvp). Feature gate stays customer_entities.
model Pet {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  customerId  String    @map("customer_id")
  name        String
  species     String?
  breed       String?
  birthDate   DateTime? @map("birth_date")
  size        String?
  sex         PetSex?
  weightKg    Decimal?  @map("weight_kg") @db.Decimal(6, 2)
  neutered    Boolean?
  temperament String[]  @default([])
  healthNotes String?   @map("health_notes")
  status      PetStatus @default(active)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@map("pets")
}

// Tenant-scoped lead (feature: lead_management). Distinct from the public
// landing `Lead` (no tenant): this is the WhatsApp/CRM lead that converts into a
// Customer. Conversion preserves any existing Customer data and links both ways
// via Customer.leadId / CustomerLead.convertedCustomerId (plain columns, no FK,
// to avoid a circular relation). See src/lib/customers/lead-conversion.ts.
enum CustomerLeadStatus {
  new
  contacted
  qualified
  converted
  discarded
}

model CustomerLead {
  id                  String             @id @default(uuid())
  tenantId            String             @map("tenant_id")
  name                String?
  phone               String?
  phoneNormalized     String?            @map("phone_normalized")
  whatsapp            String?
  whatsappNormalized  String?            @map("whatsapp_normalized")
  email               String?
  source              CustomerSource?
  status              CustomerLeadStatus @default(new)
  message             String?
  customData          Json               @default("{}") @map("custom_data")
  convertedCustomerId String?            @map("converted_customer_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // One lead per phone, per tenant (WhatsApp dedup key; NULLs stay distinct).
  @@unique([tenantId, phoneNormalized])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, whatsappNormalized])
  @@map("customer_leads")
}

// ── Tenant team / collaborators (feature: collaborator_management) ──────────
enum CollaboratorStatus {
  active
  inactive
}

enum CollaboratorRoleStatus {
  active
  inactive
}

enum CollaboratorDepartmentStatus {
  active
  inactive
}

model CollaboratorRole {
  id          String                 @id @default(uuid())
  tenantId    String                 @map("tenant_id")
  name        String
  slug        String
  description String?
  status      CollaboratorRoleStatus @default(active)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collaborators Collaborator[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("collaborator_roles")
}

model CollaboratorDepartment {
  id          String                       @id @default(uuid())
  tenantId    String                       @map("tenant_id")
  name        String
  slug        String
  description String?
  status      CollaboratorDepartmentStatus @default(active)
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collaborators Collaborator[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("collaborator_departments")
}

model Collaborator {
  id                    String             @id @default(uuid())
  tenantId              String             @map("tenant_id")
  userId                String?            @map("user_id")
  professionalId        String?            @map("professional_id")
  roleId                String?            @map("role_id")
  departmentId          String?            @map("department_id")
  name                  String
  avatarUrl             String?            @map("avatar_url")
  phone                 String?
  phoneNormalized       String?            @map("phone_normalized")
  whatsapp              String?
  whatsappNormalized    String?            @map("whatsapp_normalized")
  email                 String?
  document              String?
  documentNormalized    String?            @map("document_normalized")
  status                CollaboratorStatus @default(active)
  hasSystemAccess       Boolean            @default(false) @map("has_system_access")
  tenantRole            TenantUserRole?    @map("tenant_role")
  isServiceProfessional Boolean            @default(false) @map("is_service_professional")
  internalNotes         String?            @map("internal_notes")
  customData            Json               @default("{}") @map("custom_data")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  professional Professional?           @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  // Roles/departments with members cannot be deleted (Restrict) — actions
  // surface a friendly "inactivate instead" message before the DB constraint.
  role         CollaboratorRole?       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  department   CollaboratorDepartment? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@index([tenantId, professionalId])
  @@index([tenantId, documentNormalized])
  @@map("collaborators")
}

// ── Offer plans & packages (feature: plans_catalog) ────────────────────────
// OfferPlan is what the TENANT sells to its end customers (recurring plan /
// prepaid package / combo) — NOT the platform BillingPlan that charges the
// tenant. customData is validated against the active Template (entity_type =
// plan). Niche-specific fields never get hardcoded here. Customer subscription
// / billing is out of scope for this module.
enum OfferPlanType {
  recurring_plan
  prepaid_package
  combo
}

enum OfferPlanStatus {
  draft
  active
  inactive
}

enum OfferPlanBillingCycle {
  monthly
  quarterly
  semiannual
  yearly
}

enum OfferPlanCategoryStatus {
  active
  inactive
}

model OfferPlanCategory {
  id          String                  @id @default(uuid())
  tenantId    String                  @map("tenant_id")
  name        String
  slug        String
  description String?
  status      OfferPlanCategoryStatus @default(active)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offerPlans OfferPlan[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("offer_plan_categories")
}

model OfferPlan {
  id               String                 @id @default(uuid())
  tenantId         String                 @map("tenant_id")
  categoryId       String?                @map("category_id")
  name             String
  slug             String
  description      String?
  type             OfferPlanType
  price            Decimal                @db.Decimal(12, 2)
  promotionalPrice Decimal?               @map("promotional_price") @db.Decimal(12, 2)
  billingCycle     OfferPlanBillingCycle? @map("billing_cycle")
  autoRenew        Boolean                @default(false) @map("auto_renew")
  expiresAfterDays Int?                   @map("expires_after_days")
  usageLimit       Int?                   @map("usage_limit")
  allowScheduling  Boolean                @default(true) @map("allow_scheduling")
  status           OfferPlanStatus        @default(draft)
  availableForSale Boolean                @default(true) @map("available_for_sale")
  imageUrl         String?                @map("image_url")
  internalNotes    String?                @map("internal_notes")
  customData       Json                   @default("{}") @map("custom_data")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Categories with plans cannot be deleted (Restrict) — the action surfaces a
  // friendly "inactivate instead" message before reaching the DB constraint.
  category     OfferPlanCategory?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  serviceItems OfferPlanServiceItem[]
  productItems OfferPlanProductItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, categoryId])
  @@map("offer_plans")
}

model OfferPlanServiceItem {
  id                      String   @id @default(uuid())
  tenantId                String   @map("tenant_id")
  offerPlanId             String   @map("offer_plan_id")
  serviceId               String   @map("service_id")
  quantity                Int      @default(1)
  usageLimit              Int?     @map("usage_limit")
  durationOverrideMinutes Int?     @map("duration_override_minutes")
  priceOverride           Decimal? @map("price_override") @db.Decimal(12, 2)
  included                Boolean  @default(true)
  sortOrder               Int      @default(0) @map("sort_order")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offerPlan OfferPlan @relation(fields: [offerPlanId], references: [id], onDelete: Cascade)
  // Deleting a service drops it from any plan (the plan stays; the line goes).
  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([offerPlanId, serviceId])
  @@index([tenantId])
  @@index([offerPlanId])
  @@index([serviceId])
  @@map("offer_plan_service_items")
}

model OfferPlanProductItem {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  offerPlanId   String   @map("offer_plan_id")
  productId     String   @map("product_id")
  quantity      Int      @default(1)
  usageLimit    Int?     @map("usage_limit")
  priceOverride Decimal? @map("price_override") @db.Decimal(12, 2)
  included      Boolean  @default(true)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offerPlan OfferPlan @relation(fields: [offerPlanId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([offerPlanId, productId])
  @@index([tenantId])
  @@index([offerPlanId])
  @@index([productId])
  @@map("offer_plan_product_items")
}

// ── Tenant orders (feature: orders) — spec-crud-orders ─────────────────────
// Mercado Pago integration and automatic Appointment generation are deferred:
// OrderPayment supports provider=manual now; productId/serviceId/offerPlanId/
// appointmentId/customerAddressId are forward-compat snapshot columns (no FK)
// so catalog/address/appointment changes never rewrite a placed order.
enum OrderSource {
  whatsapp
  manual
  instagram
  website
  api
  other
}

enum OrderChannel {
  whatsapp
  panel
  api
  other
}

enum OrderStatus {
  draft
  pending_confirmation
  confirmed
  scheduled
  in_progress
  ready
  out_for_delivery
  completed
  cancelled
}

enum OrderFulfillmentType {
  delivery
  pickup
  at_location
  at_home
  online
}

enum OrderDiscountType {
  fixed
  percentage
}

enum OrderPaymentMethod {
  pix
  credit_card
  debit_card
  cash
  bank_transfer
  payment_link
  other
}

enum OrderPaymentStatus {
  pending
  paid
  partial
  refunded
  cancelled
  failed
}

enum OrderItemType {
  product
  service
  offer_plan
  custom
}

enum OrderAddressType {
  delivery
  pickup
  at_location
  at_home
  billing
  other
}

enum PaymentProvider {
  mercado_pago
  manual
}

model OrderSequence {
  id         String   @id @default(uuid())
  tenantId   String   @unique @map("tenant_id")
  // Highest order number assigned so far for the tenant; incremented atomically
  // inside the create transaction. New order number = this value after increment.
  nextNumber Int      @default(0) @map("next_number")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("order_sequences")
}

model Order {
  id              String                @id @default(uuid())
  tenantId        String                @map("tenant_id")
  orderNumber     Int                   @map("order_number")
  orderCode       String                @map("order_code")
  customerId      String                @map("customer_id")
  source          OrderSource
  channel         OrderChannel
  status          OrderStatus           @default(draft)
  fulfillmentType OrderFulfillmentType? @map("fulfillment_type")
  subtotal        Decimal               @default(0) @db.Decimal(12, 2)
  discountType    OrderDiscountType?    @map("discount_type")
  discountValue   Decimal?              @map("discount_value") @db.Decimal(12, 2)
  deliveryFee     Decimal?              @map("delivery_fee") @db.Decimal(12, 2)
  total           Decimal               @default(0) @db.Decimal(12, 2)
  paymentMethod   OrderPaymentMethod?   @map("payment_method")
  paymentStatus   OrderPaymentStatus    @default(pending) @map("payment_status")
  amountPaid      Decimal               @default(0) @map("amount_paid") @db.Decimal(12, 2)
  customerNotes   String?               @map("customer_notes")
  internalNotes   String?               @map("internal_notes")
  customData      Json                  @default("{}") @map("custom_data")
  confirmedAt     DateTime?             @map("confirmed_at")
  cancelledAt     DateTime?             @map("cancelled_at")
  completedAt     DateTime?             @map("completed_at")
  createdByUserId String?               @map("created_by_user_id")
  createdByAgent  Boolean               @default(false) @map("created_by_agent")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         OrderItem[]
  addresses     OrderAddress[]
  payments      OrderPayment[]
  statusHistory OrderStatusHistory[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
  @@index([tenantId, customerId])
  @@map("orders")
}

model OrderItem {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  orderId          String        @map("order_id")
  itemType         OrderItemType @map("item_type")
  productId        String?       @map("product_id")
  serviceId        String?       @map("service_id")
  offerPlanId      String?       @map("offer_plan_id")
  name             String
  description      String?
  quantity         Decimal       @db.Decimal(12, 2)
  unitPrice        Decimal       @map("unit_price") @db.Decimal(12, 2)
  discountValue    Decimal?      @map("discount_value") @db.Decimal(12, 2)
  total            Decimal       @db.Decimal(12, 2)
  scheduledStartAt DateTime?     @map("scheduled_start_at")
  scheduledEndAt   DateTime?     @map("scheduled_end_at")
  appointmentId    String?       @map("appointment_id")
  metadata         Json          @default("{}")
  sortOrder        Int           @default(0) @map("sort_order")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

model OrderAddress {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  orderId           String           @map("order_id")
  customerAddressId String?          @map("customer_address_id")
  type              OrderAddressType
  name              String?
  zipCode           String?          @map("zip_code")
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  country           String           @default("BR")
  reference         String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("order_addresses")
}

model OrderPayment {
  id                   String             @id @default(uuid())
  tenantId             String             @map("tenant_id")
  orderId              String             @map("order_id")
  provider             PaymentProvider    @default(manual)
  method               OrderPaymentMethod
  status               OrderPaymentStatus @default(pending)
  amount               Decimal            @db.Decimal(12, 2)
  amountPaid           Decimal            @default(0) @map("amount_paid") @db.Decimal(12, 2)
  providerPaymentId    String?            @map("provider_payment_id")
  providerPreferenceId String?            @map("provider_preference_id")
  providerStatus       String?            @map("provider_status")
  paymentUrl           String?            @map("payment_url")
  qrCode               String?            @map("qr_code")
  qrCodeBase64         String?            @map("qr_code_base64")
  expiresAt            DateTime?          @map("expires_at")
  paidAt               DateTime?          @map("paid_at")
  rawProviderData      Json?              @map("raw_provider_data")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([providerPaymentId])
  @@map("order_payments")
}

model OrderStatusHistory {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  orderId         String       @map("order_id")
  fromStatus      OrderStatus? @map("from_status")
  toStatus        OrderStatus  @map("to_status")
  changedByUserId String?      @map("changed_by_user_id")
  changedByAgent  Boolean      @default(false) @map("changed_by_agent")
  reason          String?
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("order_status_history")
}

// ── Tenant appointments (feature: appointment_request) — spec-crud-appointments ──
// Reminders are prepared but not auto-sent. customerEntityId/professionalId/
// locationId/orderId/orderItemId/rescheduledFromId are plain indexed columns
// (validated server-side) to keep the cross-model relation graph small; the
// required tenant/customer/service refs are real FKs.
enum AppointmentResponsibleType {
  professional
  tenant
}

enum AppointmentModality {
  at_location
  at_home
  online
}

enum AppointmentStatus {
  requested
  pending_confirmation
  confirmed
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum AppointmentSource {
  manual
  whatsapp
  order
  ai
  api
  other
}

enum AppointmentReminderChannel {
  whatsapp
  email
  sms
  internal
}

enum AppointmentReminderStatus {
  pending
  sent
  failed
  cancelled
}

model Appointment {
  id                String                     @id @default(uuid())
  tenantId          String                     @map("tenant_id")
  customerId        String                     @map("customer_id")
  customerEntityId  String?                    @map("customer_entity_id")
  serviceId         String                     @map("service_id")
  responsibleType   AppointmentResponsibleType @map("responsible_type")
  professionalId    String?                    @map("professional_id")
  locationId        String?                    @map("location_id")
  orderId           String?                    @map("order_id")
  orderItemId       String?                    @map("order_item_id")
  modality          AppointmentModality
  status            AppointmentStatus          @default(requested)
  source            AppointmentSource          @default(manual)
  startAt           DateTime                   @map("start_at")
  endAt             DateTime                   @map("end_at")
  timezone          String                     @default("America/Sao_Paulo")
  addressSnapshot   Json?                      @map("address_snapshot")
  customerNotes     String?                    @map("customer_notes")
  internalNotes     String?                    @map("internal_notes")
  rescheduledFromId String?                    @map("rescheduled_from_id")
  customData        Json                       @default("{}") @map("custom_data")
  createdByUserId   String?                    @map("created_by_user_id")
  createdByAgent    Boolean                    @default(false) @map("created_by_agent")
  confirmedAt       DateTime?                  @map("confirmed_at")
  cancelledAt       DateTime?                  @map("cancelled_at")
  completedAt       DateTime?                  @map("completed_at")
  noShowAt          DateTime?                  @map("no_show_at")
  createdAt         DateTime                   @default(now()) @map("created_at")
  updatedAt         DateTime                   @updatedAt @map("updated_at")

  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service       Service                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  statusHistory AppointmentStatusHistory[]
  reminders     AppointmentReminder[]

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, serviceId])
  @@index([tenantId, professionalId])
  @@index([tenantId, locationId])
  @@index([tenantId, orderId])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  appointmentId   String             @map("appointment_id")
  fromStatus      AppointmentStatus? @map("from_status")
  toStatus        AppointmentStatus  @map("to_status")
  changedByUserId String?            @map("changed_by_user_id")
  changedByAgent  Boolean            @default(false) @map("changed_by_agent")
  reason          String?
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, appointmentId])
  @@map("appointment_status_history")
}

model AppointmentReminder {
  id            String                     @id @default(uuid())
  tenantId      String                     @map("tenant_id")
  appointmentId String                     @map("appointment_id")
  channel       AppointmentReminderChannel
  scheduledFor  DateTime                   @map("scheduled_for")
  status        AppointmentReminderStatus  @default(pending)
  sentAt        DateTime?                  @map("sent_at")
  errorMessage  String?                    @map("error_message")
  metadata      Json                       @default("{}")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, appointmentId])
  @@index([tenantId, scheduledFor, status])
  @@map("appointment_reminders")
}

// ============================================================================
// WhatsApp / Messaging — provider-agnostic integration.
// See .claude/docs/specs/integrations/whatsapp/spec-pilot-status.json.
// The UI and business logic never talk to a provider directly: they go through
// the MessagingProvider interface (src/lib/messaging). Provider names, endpoint
// shapes and SDKs stay isolated in the concrete provider. Initial provider:
// pilot_status_whatsapp. Internal status is normalized and kept separate from
// the raw providerStatus so a future provider swap (Meta, Z-API, Twilio, …) has
// minimal blast radius. Every table is tenant-scoped with @@index([tenantId]).
// ============================================================================

enum MessagingProvider {
  pilot_status_whatsapp
  meta_whatsapp
  z_api
  evolution_api
  twilio
  other
}

enum MessagingEnvironment {
  test
  live
}

enum MessagingAccountStatus {
  active
  inactive
  error
  pending_setup
}

// One provider account per tenant (the resolved project + environment + the
// tenant's child API key). The parent/master API key never lives here — it
// stays in ENV. encryptedApiKey holds the AES-GCM ciphertext of the child key.
model MessagingProviderAccount {
  id                String                 @id @default(uuid())
  tenantId          String                 @map("tenant_id")
  provider          MessagingProvider      @default(pilot_status_whatsapp)
  environment       MessagingEnvironment   @default(test)
  providerProjectId String?                @map("provider_project_id")
  providerApiKeyId  String?                @map("provider_api_key_id")
  encryptedApiKey   String?                @map("encrypted_api_key")
  keyPrefix         String?                @map("key_prefix")
  retentionDays     Int                    @default(30) @map("retention_days")
  status            MessagingAccountStatus @default(pending_setup)
  metadata          Json                   @default("{}")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappAccounts WhatsAppAccount[]
  templateMappings MessageTemplateMapping[]

  @@unique([tenantId, provider, environment])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("messaging_provider_accounts")
}

enum WhatsAppAccountStatus {
  connecting
  open
  close
  disconnected
  error
  pending_pairing
}

enum WhatsAppLinkMode {
  single
  dual
}

// A connected (or connecting) WhatsApp number. MVP keeps one primary per tenant
// but the model supports several. qrcodeBase64 / pairingCode are transient
// connect artifacts and are cleared once the link is OPEN.
model WhatsAppAccount {
  id                 String                @id @default(uuid())
  tenantId           String                @map("tenant_id")
  providerAccountId  String                @map("provider_account_id")
  providerInstanceId String?               @map("provider_instance_id")
  name               String?
  number             String?
  numberNormalized   String?               @map("number_normalized")
  maskedNumber       String?               @map("masked_number")
  status             WhatsAppAccountStatus @default(pending_pairing)
  isPrimary          Boolean               @default(false) @map("is_primary")
  linkMode           WhatsAppLinkMode      @default(dual) @map("link_mode")
  primaryState       String?               @map("primary_state")
  secondaryState     String?               @map("secondary_state")
  isFullyConnected   Boolean               @default(false) @map("is_fully_connected")
  remotePairingUrl   String?               @map("remote_pairing_url")
  qrcodeBase64       String?               @map("qrcode_base64")
  pairingCode        String?               @map("pairing_code")
  lastStatusAt       DateTime?             @map("last_status_at")
  connectedAt        DateTime?             @map("connected_at")
  metadata           Json                  @default("{}")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerAccount MessagingProviderAccount @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)
  conversations   Conversation[]

  @@unique([tenantId, numberNormalized])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([providerAccountId])
  @@map("whatsapp_accounts")
}

enum ConversationChannel {
  whatsapp
}

enum ConversationTargetType {
  phone
  group
  newsletter
}

enum ConversationStatus {
  open
  pending
  resolved
  archived
  blocked
}

enum ConversationAssigneeType {
  ai
  human
  paused
  unassigned
}

model Conversation {
  id                      String                   @id @default(uuid())
  tenantId                String                   @map("tenant_id")
  whatsappAccountId       String?                  @map("whatsapp_account_id")
  channel                 ConversationChannel      @default(whatsapp)
  targetType              ConversationTargetType   @default(phone) @map("target_type")
  targetId                String?                  @map("target_id")
  targetName              String?                  @map("target_name")
  contactNumber           String?                  @map("contact_number")
  contactNumberNormalized String?                  @map("contact_number_normalized")
  groupId                 String?                  @map("group_id")
  newsletterId            String?                  @map("newsletter_id")
  customerId              String?                  @map("customer_id")
  leadId                  String?                  @map("lead_id")
  status                  ConversationStatus       @default(open)
  assigneeType            ConversationAssigneeType @default(unassigned) @map("assignee_type")
  assignedUserId          String?                  @map("assigned_user_id")
  assignedAgentId         String?                  @map("assigned_agent_id")
  lastMessageAt           DateTime?                @map("last_message_at")
  lastInboundAt           DateTime?                @map("last_inbound_at")
  lastOutboundAt          DateTime?                @map("last_outbound_at")
  unreadCount             Int                      @default(0) @map("unread_count")
  optInStatus             MessageConsentStatus     @default(unknown) @map("opt_in_status")
  metadata                Json                     @default("{}")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount?         @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)
  messages        ConversationMessage[]
  assignments     ConversationAssignment[]

  // One open conversation per phone target, per tenant (NULLs stay distinct).
  @@unique([tenantId, contactNumberNormalized])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assigneeType])
  @@index([tenantId, lastMessageAt])
  @@index([customerId])
  @@index([leadId])
  @@map("conversations")
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  text
  template
  button
  system
  group
  newsletter
  unknown
}

enum MessageInternalStatus {
  queued
  sent
  delivered
  read
  failed
  canceled
  received
}

model ConversationMessage {
  id                        String                @id @default(uuid())
  tenantId                  String                @map("tenant_id")
  conversationId            String                @map("conversation_id")
  direction                 MessageDirection
  content                   String?
  messageType               MessageType           @default(text) @map("message_type")
  internalStatus            MessageInternalStatus @default(queued) @map("internal_status")
  providerStatus            String?               @map("provider_status")
  providerMessageId         String?               @map("provider_message_id")
  providerInternalMessageId String?               @map("provider_internal_message_id")
  providerCorrelationId     String?               @map("provider_correlation_id")
  quotedMessageId           String?               @map("quoted_message_id")
  messageRepliedId          String?               @map("message_replied_id")
  templateMappingId         String?               @map("template_mapping_id")
  variables                 Json                  @default("{}")
  fromNumber                String?               @map("from_number")
  toNumber                  String?               @map("to_number")
  sentByUserId              String?               @map("sent_by_user_id")
  sentByAgent               Boolean               @default(false) @map("sent_by_agent")
  receivedAt                DateTime?             @map("received_at")
  sentAt                    DateTime?             @map("sent_at")
  deliveredAt               DateTime?             @map("delivered_at")
  readAt                    DateTime?             @map("read_at")
  failedAt                  DateTime?             @map("failed_at")
  errorMessage              String?               @map("error_message")
  metadata                  Json                  @default("{}")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation    Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  templateMapping MessageTemplateMapping? @relation(fields: [templateMappingId], references: [id], onDelete: SetNull)
  deliveries      MessageDelivery[]

  // Idempotency: a given provider message lands once per tenant (NULLs distinct).
  @@unique([tenantId, providerMessageId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([tenantId, internalStatus])
  @@index([providerInternalMessageId])
  @@map("conversation_messages")
}

model MessageDelivery {
  id                    String                @id @default(uuid())
  tenantId              String                @map("tenant_id")
  conversationMessageId String                @map("conversation_message_id")
  provider              MessagingProvider     @default(pilot_status_whatsapp)
  providerStatus        String?               @map("provider_status")
  internalStatus        MessageInternalStatus @map("internal_status")
  rawEventId            String?               @map("raw_event_id")
  happenedAt            DateTime?             @map("happened_at")
  metadata              Json                  @default("{}")
  createdAt             DateTime              @default(now()) @map("created_at")

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationMessage ConversationMessage @relation(fields: [conversationMessageId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationMessageId])
  @@map("message_deliveries")
}

enum TemplateCategory {
  otp
  utility
  marketing
  unknown
}

enum TemplateMappingStatus {
  draft
  approved
  rejected
  pending
  unknown
}

model MessageTemplateMapping {
  id                 String                @id @default(uuid())
  tenantId           String                @map("tenant_id")
  providerAccountId  String                @map("provider_account_id")
  providerTemplateId String                @map("provider_template_id")
  name               String
  category           TemplateCategory      @default(unknown)
  language           String?
  variables          Json                  @default("[]")
  status             TemplateMappingStatus @default(unknown)
  isDefault          Boolean               @default(false) @map("is_default")
  metadata           Json                  @default("{}")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerAccount MessagingProviderAccount @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)
  messages        ConversationMessage[]

  @@unique([tenantId, providerTemplateId])
  @@index([tenantId])
  @@index([providerAccountId])
  @@index([tenantId, category])
  @@map("message_template_mappings")
}

enum WebhookProcessingStatus {
  received
  processed
  failed
  ignored
  duplicate
}

// Every inbound webhook is logged BEFORE processing, with a masked payload for
// the UI. tenantId is nullable: a webhook may arrive before we can resolve the
// owning tenant. Idempotency is enforced per provider event id.
model MessageWebhookEventLog {
  id                String                  @id @default(uuid())
  tenantId          String?                 @map("tenant_id")
  provider          MessagingProvider       @default(pilot_status_whatsapp)
  providerAccountId String?                 @map("provider_account_id")
  eventType         String                  @map("event_type")
  providerEventId   String?                 @map("provider_event_id")
  correlationId     String?                 @map("correlation_id")
  messageId         String?                 @map("message_id")
  internalMessageId String?                 @map("internal_message_id")
  payload           Json                    @default("{}")
  maskedPayload     Json                    @default("{}") @map("masked_payload")
  processingStatus  WebhookProcessingStatus @default(received) @map("processing_status")
  errorMessage      String?                 @map("error_message")
  receivedAt        DateTime                @default(now()) @map("received_at")
  processedAt       DateTime?               @map("processed_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([tenantId])
  @@index([eventType])
  @@index([receivedAt])
  @@index([correlationId])
  @@map("message_webhook_event_logs")
}

enum MessageConsentStatus {
  unknown
  opted_in
  opted_out
  required
  not_required
}

model MessageConsent {
  id                 String               @id @default(uuid())
  tenantId           String               @map("tenant_id")
  customerId         String?              @map("customer_id")
  leadId             String?              @map("lead_id")
  phoneNormalized    String               @map("phone_normalized")
  channel            ConversationChannel  @default(whatsapp)
  optInStatus        MessageConsentStatus @default(unknown) @map("opt_in_status")
  optInSource        String?              @map("opt_in_source")
  optInAt            DateTime?            @map("opt_in_at")
  optOutAt           DateTime?            @map("opt_out_at")
  lastSeenAt         DateTime?            @map("last_seen_at")
  providerRequired   Boolean?             @map("provider_required")
  providerAuthorized Boolean?             @map("provider_authorized")
  metadata           Json                 @default("{}")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, phoneNormalized])
  @@index([tenantId])
  @@index([tenantId, optInStatus])
  @@map("message_consents")
}

model ConversationAssignment {
  id              String                   @id @default(uuid())
  tenantId        String                   @map("tenant_id")
  conversationId  String                   @map("conversation_id")
  assigneeType    ConversationAssigneeType @map("assignee_type")
  assignedUserId  String?                  @map("assigned_user_id")
  assignedAgentId String?                  @map("assigned_agent_id")
  reason          String?
  createdAt       DateTime                 @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
  @@map("conversation_assignments")
}

enum McpAccessTokenStatus {
  active
  revoked
}

// Per-tenant bearer token for the remote MCP server (/api/mcp) consumed by the
// Zatten agent. One token = one tenant: verifyMcpBearer hashes the incoming
// bearer (sha256) and resolves tenant_id from here — tenant_id is NEVER taken
// from tool input. Only the hash is stored; the plaintext is shown once on mint.
// See .claude/docs/specs/integrations/zatten-mcp/spec-zatten-mcp.md.
model McpAccessToken {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  name            String
  tokenHash       String               @unique @map("token_hash")
  tokenPrefix     String               @map("token_prefix")
  scopes          String[]             @default(["read"])
  status          McpAccessTokenStatus @default(active)
  lastUsedAt      DateTime?            @map("last_used_at")
  expiresAt       DateTime?            @map("expires_at")
  createdByUserId String?              @map("created_by_user_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("mcp_access_tokens")
}
